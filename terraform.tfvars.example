# AWS Configuration
aws_region = "us-east-1"

# SSH Access
key_pair_name = "your-key-pair-name"

# Security
restricted_ip = "203.0.113.10/32"  # Replace with your admin IP
admin_email = "your-email@example.com"

# Compute Resources
compute_instance_type = "t3.micro"

# SSL Certificate (optional)
alb_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/12345678-1234-1234-1234-123456789012"

# AMI (Ubuntu 20.04 LTS for us-east-1)
ubuntu_ami = "ami-0a59ec92177ec3fad"

# VPC CIDRs
vpc_cidr_hub = "10.160.0.0/16"
vpc_cidr_compute = "10.161.0.0/16"
vpc_cidr_dev = "10.162.0.0/16"
vpc_cidr_egress = "10.163.0.0/16"